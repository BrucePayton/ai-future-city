OPENCLAW_LOCAL_URL=ws://localhost:18789
OPENCLAW_LOCAL_TOKEN=
OPENCLAW_LOCAL_AGENT_ID=default
# Optional: platform-persona OpenClaw for training (e.g. sync-cli-started instance on 18790). When set, training/chat uses this; other traffic uses OPENCLAW_LOCAL_URL.
# OPENCLAW_PLATFORM_URL=ws://localhost:18790
# OPENCLAW_PLATFORM_TOKEN=
# Optional: sync-cli uses this to override openclawPort (default 18790). Must match OPENCLAW_PLATFORM_URL port when set.
# OPENCLAW_PLATFORM_PORT=18790
# Inbound: when gateway is on server and OpenClaw on your PC, set token for bridge register (optional; can reuse OPENCLAW_LOCAL_TOKEN)
# OPENCLAW_INBOUND_TOKEN=
# OPENCLAW_INBOUND_WS_PATH=/ws/openclaw-inbound
# Bridge (run on PC): gateway inbound WebSocket URL
# GATEWAY_WS_URL=wss://your-server:3001/ws/openclaw-inbound

# === SaaS Cloud Mode Configuration ===
# Enable cloud mode (true/1) or hybrid mode (auto fallback)
AIFC_CLOUD_MODE=false
# Cloud API endpoint (e.g., https://api.aifuturecity.com)
AIFC_CLOUD_URL=
# API Key for cloud authentication
AIFC_API_KEY=
# Organization ID for multi-tenancy
# AIFC_ORGANIZATION_ID=

OPENCLAW_CHAT_SESSION_KEY=test-workspace-001
OPENCLAW_CHAT_SESSION_KEY=test-workspace-001
OPENCLAW_TOOL_NAME=
OPENCLAW_TOOL_INPUT_JSON={}
OPENCLAW_BASE_URL=http://localhost:18789
OPENCLAW_REST_TOKEN=
AIFC_GATEWAY_PORT=3001
# Optional: PostgreSQL connection URL. When set, assistants state is stored in PG instead of data/assistants.json
# DATABASE_URL=postgresql://user:password@localhost:5432/aifuturecity
AIFC_GATEWAY_WS_PATH=/ws
AIFC_PLATFORM_URL=wss://platform.aifuturecity.local/device
AIFC_DEVICE_ID=my-pc-agent-001
AIFC_PLATFORM_TOKEN=
NEXT_PUBLIC_GATEWAY_HTTP_URL=http://localhost:3001
NEXT_PUBLIC_GATEWAY_WS_URL=ws://localhost:3001/ws
