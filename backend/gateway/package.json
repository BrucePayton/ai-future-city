{
  "name": "@aifc/backend-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @aifc/client-openclaw-adapter build && tsc -p tsconfig.json",
